{
  "name": "boredom-at-work-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "indexnow": "node scripts/indexnow.js --changed",
    "preview": "astro preview",
    "astro": "astro",
    "stats": "node scripts/update-stats.js",
    "optimize": "node scripts/optimize.js",
    "lint:content": "node scripts/content-lint.js",
    "lint:content:fix": "node scripts/content-lint.js --fix",
    "traffic": "node scripts/gsc-traffic.js && node scripts/bing-traffic.js",
    "traffic:gsc": "node scripts/gsc-traffic.js",
    "traffic:bing": "node scripts/bing-traffic.js",
    "traffic:queries": "node scripts/gsc-traffic.js --queries && node scripts/bing-traffic.js --queries",
    "traffic:cluster": "node scripts/gsc-traffic.js --cluster && node scripts/bing-traffic.js --cluster",
    "export:articles": "node scripts/export-articles.js"
  },
  "dependencies": {
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.3",
    "astro-seo": "^1.1.0",
    "markdown-it": "^14.2.0",
    "pagefind": "^1.5.2",
    "rehype-external-links": "^3.0.0",
    "sanitize-html": "^2.17.5",
    "tailwindcss": "^4.3.1",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "sharp": "^0.35.2"
  }
}
