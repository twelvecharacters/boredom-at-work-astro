<script type="text/partytown" src={`https://www.googletagmanager.com/gtag/js?id=GT-PL3RVFQX`}></script>
<script type="text/partytown">
  window.dataLayer = window.dataLayer || [];
  window.gtag = function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'GT-PL3RVFQX');

  // 1. Scroll depth tracking (25/50/75/100%)
  var scrollMarks = [25, 50, 75, 100];
  var firedMarks = {};
  window.addEventListener('scroll', function() {
    var scrollPct = Math.round(100 * (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight);
    for (var i = 0; i < scrollMarks.length; i++) {
      if (scrollPct >= scrollMarks[i] && !firedMarks[scrollMarks[i]]) {
        firedMarks[scrollMarks[i]] = true;
        gtag('event', 'scroll', { percent_scrolled: scrollMarks[i] });
      }
    }
  }, { passive: true });

  // 2. Outbound link click tracking
  document.addEventListener('click', function(e) {
    var link = e.target.closest('a[href]');
    if (!link) return;
    var href = link.getAttribute('href');
    if (href && href.startsWith('http') && !href.includes('boredom-at-work.com')) {
      try {
        var urlObj = new URL(href);
        gtag('event', 'outbound_click', {
          link_url: href,
          link_domain: urlObj.hostname
        });
      } catch(e) {
        // Fallback if URL parsing fails
        gtag('event', 'outbound_click', { link_url: href });
      }
    }
  });

  // 3. Form Submission tracking
  document.addEventListener('submit', function(e) {
    if (e.target.tagName === 'FORM') {
      gtag('event', 'form_submit', {
        form_id: e.target.id || 'unknown',
        form_destination: e.target.action || 'unknown'
      });
    }
  });

  // 4. Search Term tracking (Assuming a search input in a form or a URL parameter)
  var urlParams = new URLSearchParams(window.location.search);
  if (urlParams.has('q')) {
    gtag('event', 'view_search_results', { search_term: urlParams.get('q') });
  }

  // 5. Time-on-Page / Engagement Heartbeat (every 30 seconds)
  setInterval(function() {
    gtag('event', 'engagement_heartbeat', { duration_seconds: 30 });
  }, 30000);
</script>
