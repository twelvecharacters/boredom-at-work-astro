---
const ais = [
  {
    rank: 1,
    name: 'Claude',
    company: 'Anthropic',
    icon: '🧠',
    bestFor: 'Writing & Coding',
    description: 'The absolute best AI for writing human-sounding emails and generating code without bugs. Feels like a genius coworker.',
    price: 'Free / $20',
    color: 'bg-amber-500',
    textColor: 'text-amber-700',
    bgColor: 'bg-amber-50'
  },
  {
    rank: 2,
    name: 'ChatGPT',
    company: 'OpenAI',
    icon: '⚡',
    bestFor: 'The Best All-Rounder',
    description: 'Still the industry standard. Great at brainstorming, data analysis, and has the best voice mode for commuting.',
    price: 'Free / $20',
    color: 'bg-emerald-500',
    textColor: 'text-emerald-700',
    bgColor: 'bg-emerald-50'
  },
  {
    rank: 3,
    name: 'Perplexity',
    company: 'Perplexity AI',
    icon: '🔍',
    bestFor: 'Deep Research',
    description: 'Replaces Google. It searches the live web and writes a summarized report with clickable citations in seconds.',
    price: 'Free / $20',
    color: 'bg-blue-500',
    textColor: 'text-blue-700',
    bgColor: 'bg-blue-50'
  },
  {
    rank: 4,
    name: 'Cursor',
    company: 'Anysphere',
    icon: '💻',
    bestFor: 'Building Apps',
    description: 'An AI-first code editor. Even if you barely know how to code, this tool can help you build internal tools or side projects.',
    price: 'Free / $20',
    color: 'bg-purple-500',
    textColor: 'text-purple-700',
    bgColor: 'bg-purple-50'
  },
  {
    rank: 5,
    name: 'Gemini',
    company: 'Google',
    icon: '✨',
    bestFor: 'Google Workspace',
    description: 'Incredibly fast and integrates flawlessly into Docs, Sheets, and Gmail. It has a massive context window for analyzing huge documents.',
    price: 'Free / $20',
    color: 'bg-rose-500',
    textColor: 'text-rose-700',
    bgColor: 'bg-rose-50'
  }
];
---

<section class="py-24 bg-background-alt relative overflow-hidden">
  <div class="max-w-4xl mx-auto px-4 relative z-10">
    
    <!-- Header -->
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-2 bg-white border border-primary/10 px-4 py-1.5 rounded-full text-xs font-bold text-accent uppercase tracking-widest mb-6 shadow-sm">
        <span class="animate-pulse">🏆</span> Power Rankings
      </div>
      <h2 class="text-3xl md:text-5xl font-black mb-4 tracking-tight text-primary">The Top 5 AI Tools</h2>
      <p class="text-lg text-text-light max-w-2xl mx-auto">
        Don't get overwhelmed by the thousands of AI tools launching every week. These are the only 5 you actually need to do your job faster.
      </p>
    </div>

    <!-- Leaderboard -->
    <div class="flex flex-col gap-4">
      {ais.map((ai, index) => (
        <div class={`reveal delay-${index * 100} group bg-white rounded-3xl p-6 md:p-8 flex flex-col md:flex-row md:items-center gap-6 border border-primary/5 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300`}>
          
          <!-- Rank Badge -->
          <div class="hidden md:flex shrink-0 w-16 h-16 rounded-2xl bg-background-alt items-center justify-center border border-primary/5 group-hover:scale-110 transition-transform">
            <span class="text-2xl font-black text-primary/30">#{ai.rank}</span>
          </div>
          
          <!-- Icon & Title (Mobile: Rank is here) -->
          <div class="shrink-0 flex items-center gap-4 md:w-48">
            <div class={`w-12 h-12 rounded-xl flex items-center justify-center text-2xl ${ai.bgColor} border border-white`}>
              {ai.icon}
            </div>
            <div>
              <div class="flex items-center gap-2">
                <span class="md:hidden text-sm font-black text-primary/30">#{ai.rank}</span>
                <h3 class="text-xl font-bold text-primary">{ai.name}</h3>
              </div>
              <p class="text-xs font-bold text-text-light uppercase tracking-widest">{ai.company}</p>
            </div>
          </div>

          <!-- Description -->
          <div class="flex-grow">
            <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[10px] font-black uppercase tracking-widest mb-2 ${ai.bgColor} ${ai.textColor} border border-white">
              <span class={`w-1.5 h-1.5 rounded-full ${ai.color}`}></span>
              Best For: {ai.bestFor}
            </div>
            <p class="text-sm text-text-light leading-relaxed">
              {ai.description}
            </p>
          </div>

          <!-- Price -->
          <div class="shrink-0 md:text-right mt-4 md:mt-0 pt-4 md:pt-0 border-t md:border-t-0 border-primary/5">
            <p class="text-[10px] font-bold text-text-light uppercase tracking-widest mb-1">Pricing</p>
            <p class="text-sm font-black text-primary bg-background-alt px-3 py-1.5 rounded-lg inline-block">
              {ai.price}
            </p>
          </div>
          
        </div>
      ))}
    </div>

    <div class="mt-12 text-center reveal delay-500">
      <a href="/tags/ai/" class="inline-flex items-center gap-2 font-bold text-accent hover:text-primary transition-colors">
        Read our full AI mastery guides <span class="text-xl">→</span>
      </a>
    </div>

  </div>
</section>
