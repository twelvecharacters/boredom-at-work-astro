---
// Pagefind Search Component
---

<div id="search" class="search-container">
  <div class="pagefind-ui__form" id="search-placeholder">
    <input type="text" class="pagefind-ui__search-input" placeholder="Search..." readonly />
  </div>
</div>
<script is:inline>
  (function() {
    var loaded = false;
    var placeholder = document.getElementById('search-placeholder');
    if (!placeholder) return;

    function loadPagefind() {
      if (loaded) return;
      loaded = true;
      placeholder.remove();

      var cssLink = document.createElement('link');
      cssLink.rel = 'stylesheet';
      cssLink.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(cssLink);

      var script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = function() {
        var pf = new PagefindUI({
          element: "#search",
          showSubResults: false,
          showImages: false,
          translations: {
            placeholder: "Search...",
            zero_results: "Nothing found"
          }
        });
        var input = document.querySelector('#search .pagefind-ui__search-input');
        if (input) input.focus();
      };
      document.head.appendChild(script);
    }

    placeholder.addEventListener('click', loadPagefind);
    placeholder.addEventListener('focusin', loadPagefind);
  })();
</script>

<style is:global>
  /* Search container - fixed width */
  .search-container {
    position: relative;
    width: 200px !important;
    max-width: 200px !important;
    min-width: 200px !important;
    flex-shrink: 0 !important;
    flex-grow: 0 !important;
  }

  /* Pagefind UI variables */
  .search-container {
    --pagefind-ui-scale: 0.8;
    --pagefind-ui-primary: #8b5cf6;
    --pagefind-ui-text: #1e1b4b;
    --pagefind-ui-background: white;
    --pagefind-ui-border: #2d1f4a;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
  }

  /* Placeholder input (before pagefind loads) */
  #search-placeholder .pagefind-ui__search-input {
    background-color: rgba(255, 255, 255, 0.15) !important;
    color: white !important;
    border: 1px solid rgba(255, 255, 255, 0.3) !important;
    width: 100% !important;
    box-sizing: border-box !important;
    padding: 0.4rem 0.6rem;
    font-size: 0.8rem;
    border-radius: 8px;
    outline: none;
    cursor: pointer;
  }

  #search-placeholder .pagefind-ui__search-input::placeholder {
    color: rgba(255, 255, 255, 0.7) !important;
  }

  /* Constrain all inner elements */
  .search-container .pagefind-ui {
    width: 100% !important;
  }

  .search-container .pagefind-ui__form {
    position: relative;
    width: 100% !important;
    max-width: 100% !important;
  }

  /* Style the search input for dark header */
  .search-container .pagefind-ui__search-input {
    background-color: rgba(255, 255, 255, 0.15) !important;
    color: white !important;
    border: 1px solid rgba(255, 255, 255, 0.3) !important;
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
  }

  .search-container .pagefind-ui__search-input:focus {
    background-color: rgba(255, 255, 255, 0.25) !important;
  }

  .search-container .pagefind-ui__search-input::placeholder {
    color: rgba(255, 255, 255, 0.7) !important;
  }

  /* Search button/icon - hide the clear button background */
  .search-container .pagefind-ui__search-clear {
    color: white !important;
    background-color: transparent !important;
  }

  /* Hide the clear button completely if needed */
  .search-container .pagefind-ui__search-clear::before {
    background-color: transparent !important;
  }

  /* Results dropdown - dark theme matching header */
  .search-container .pagefind-ui__drawer {
    position: absolute;
    right: 0;
    top: 100%;
    margin-top: 0.5rem;
    background: linear-gradient(to right, #11153b, #2d1f4a) !important;
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: 0.5rem;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
    min-width: 300px;
    max-width: 400px;
    max-height: 70vh;
    overflow-y: auto;
    z-index: 1000;
  }

  .search-container .pagefind-ui__result-title {
    color: white !important;
    font-weight: 600;
  }

  .search-container .pagefind-ui__result-link {
    color: rgba(255, 255, 255, 0.8) !important;
  }

  .search-container .pagefind-ui__result-link:hover {
    background-color: rgba(139, 92, 246, 0.2) !important;
  }

  .search-container .pagefind-ui__message {
    color: rgba(255, 255, 255, 0.7) !important;
    font-size: 1rem !important;
    font-weight: 600 !important;
    padding: 0.75rem 1rem !important;
  }

  .search-container .pagefind-ui__result-title {
    font-size: 0.875rem !important;
  }

  /* Hide sub-results and excerpts - only show main article titles */
  .search-container .pagefind-ui__result-nested,
  .search-container .pagefind-ui__result-excerpt,
  .search-container .pagefind-ui__result-inner .pagefind-ui__result-excerpt,
  .pagefind-ui__result-nested,
  .pagefind-ui__result-excerpt,
  [class*="pagefind"] [class*="nested"],
  [class*="pagefind"] [class*="excerpt"] {
    display: none !important;
    visibility: hidden !important;
    height: 0 !important;
    max-height: 0 !important;
    overflow: hidden !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  /* Clean result styling - just title */
  .search-container .pagefind-ui__result {
    padding: 0.75rem 1rem !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
  }

  .search-container .pagefind-ui__result-inner {
    gap: 0 !important;
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .search-container {
      width: 150px !important;
      max-width: 150px !important;
      min-width: 150px !important;
    }

    .search-container .pagefind-ui__drawer {
      position: fixed !important;
      left: 1rem !important;
      right: 1rem !important;
      top: 60px !important;
      bottom: auto !important;
      min-width: auto !important;
      max-width: none !important;
      max-height: 300px !important;
      height: auto !important;
      overflow-y: auto !important;
    }

    /* Force hide sub-results on mobile */
    .search-container .pagefind-ui__result-nested,
    .search-container .pagefind-ui__result-excerpt,
    .pagefind-ui__result-nested,
    .pagefind-ui__result-excerpt {
      display: none !important;
      visibility: hidden !important;
      height: 0 !important;
      overflow: hidden !important;
    }
  }
</style>
