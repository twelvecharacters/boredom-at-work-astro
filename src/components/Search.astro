---
// Pagefind Search Component
---

<div id="search" class="search-container">
  <div class="pagefind-ui__form" id="search-placeholder">
    <div class="search-icon-wrapper">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </div>
    <input type="text" class="pagefind-ui__search-input" placeholder="Search guides..." readonly />
  </div>
</div>

<script is:inline>
  (function() {
    var loaded = false;
    var placeholder = document.getElementById('search-placeholder');
    if (!placeholder) return;

    function loadPagefind() {
      if (loaded) return;
      loaded = true;
      
      // Keep placeholder until script loads for better UX
      var cssLink = document.createElement('link');
      cssLink.rel = 'stylesheet';
      cssLink.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(cssLink);

      var script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = function() {
        placeholder.remove();
        var pf = new PagefindUI({
          element: "#search",
          showSubResults: true,
          showImages: true,
          resetStyles: false,
          translations: {
            placeholder: "Search guides...",
            zero_results: "No guides found for [SEARCH_TERM]"
          }
        });
        var input = document.querySelector('#search .pagefind-ui__search-input');
        if (input) input.focus();
      };
      document.head.appendChild(script);
    }

    placeholder.addEventListener('click', loadPagefind);
    placeholder.addEventListener('focusin', loadPagefind);
  })();
</script>

<style is:global>
  :root {
    --pagefind-ui-primary: var(--color-accent, #8b5cf6);
    --pagefind-ui-text: #ffffff;
    --pagefind-ui-background: rgba(17, 21, 59, 0.95);
    --pagefind-ui-border: rgba(139, 92, 246, 0.3);
    --pagefind-ui-font: var(--font-body, inherit);
  }

  .search-container {
    position: relative;
    width: 240px;
    z-index: 60;
  }

  /* Custom Search Icon */
  .search-icon-wrapper {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.5);
    pointer-events: none;
    z-index: 2;
  }

  /* Placeholder Styling */
  #search-placeholder {
    position: relative;
    cursor: pointer;
  }

  #search-placeholder .pagefind-ui__search-input {
    padding-left: 36px !important;
    background: rgba(255, 255, 255, 0.1) !important;
    border: 1px solid rgba(255, 255, 255, 0.2) !important;
    backdrop-blur: 8px;
    border-radius: 12px !important;
    color: white !important;
    height: 42px !important;
    font-size: 0.9rem !important;
    transition: all 0.3s ease !important;
  }

  #search-placeholder:hover .pagefind-ui__search-input {
    background: rgba(255, 255, 255, 0.15) !important;
    border-color: rgba(255, 255, 255, 0.3) !important;
  }

  /* Pagefind Overrides */
  .pagefind-ui__search-input {
    background: rgba(255, 255, 255, 0.1) !important;
    border: 1px solid rgba(255, 255, 255, 0.2) !important;
    border-radius: 12px !important;
    color: white !important;
    padding: 10px 12px 10px 40px !important;
    font-size: 0.9rem !important;
    width: 100%;
  }

  .pagefind-ui__search-input:focus {
    outline: none !important;
    border-color: var(--color-accent) !important;
    background: rgba(255, 255, 255, 0.15) !important;
    box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.2) !important;
  }

  .pagefind-ui__drawer {
    position: absolute !important;
    top: calc(100% + 12px) !important;
    right: 0 !important;
    width: 450px !important;
    background: rgba(17, 21, 59, 0.8) !important;
    backdrop-filter: blur(20px) saturate(180%) !important;
    -webkit-backdrop-filter: blur(20px) saturate(180%) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    border-radius: 20px !important;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5) !important;
    padding: 8px !important;
    max-height: 500px !important;
    overflow-y: auto !important;
  }

  .pagefind-ui__result {
    list-style: none !important;
    padding: 12px !important;
    border-radius: 12px !important;
    transition: all 0.2s ease !important;
    border: none !important;
    margin-bottom: 4px !important;
  }

  .pagefind-ui__result:hover {
    background: rgba(255, 255, 255, 0.05) !important;
  }

  .pagefind-ui__result-link {
    color: white !important;
    font-weight: 700 !important;
    font-size: 1rem !important;
    text-decoration: none !important;
    display: block !important;
    margin-bottom: 4px !important;
  }

  .pagefind-ui__result-excerpt {
    color: rgba(255, 255, 255, 0.6) !important;
    font-size: 0.85rem !important;
    line-height: 1.5 !important;
  }

  .pagefind-ui__result-excerpt mark {
    background: rgba(139, 92, 246, 0.3) !important;
    color: var(--color-accent) !important;
    border-radius: 2px !important;
    padding: 0 2px !important;
  }

  .pagefind-ui__result-thumb {
    border-radius: 8px !important;
    width: 80px !important;
    aspect-ratio: 16/9 !important;
    object-fit: cover !important;
  }

  .pagefind-ui__message {
    padding: 16px !important;
    font-size: 0.9rem !important;
    color: rgba(255, 255, 255, 0.5) !important;
    font-weight: 600 !important;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .search-container {
      width: 42px; /* Just an icon-like look on mobile initially */
      transition: width 0.3s ease;
    }

    .search-container:focus-within {
      width: 180px;
    }

    .pagefind-ui__drawer {
      position: fixed !important;
      left: 16px !important;
      right: 16px !important;
      top: 80px !important;
      width: auto !important;
      max-height: 60vh !important;
    }
    
    #search-placeholder .pagefind-ui__search-input::placeholder {
      color: transparent !important;
    }
  }

  /* Custom Scrollbar for Drawer */
  .pagefind-ui__drawer::-webkit-scrollbar {
    width: 6px;
  }
  .pagefind-ui__drawer::-webkit-scrollbar-track {
    background: transparent;
  }
  .pagefind-ui__drawer::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
  }
</style>
