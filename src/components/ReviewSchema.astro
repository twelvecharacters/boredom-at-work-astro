---
import { SITE } from '../config';
import { parseOffers } from '../utils/schema';

interface Props {
  review: {
    rating: number;
    productName: string;
    productBrand?: string;
    priceRange?: string;
    reviewBody?: string;
  };
  articleTitle: string;
  articleDescription: string;
  articleUrl: string;
  articleImage?: string;
  publishDate: Date;
  author: string;
}

const { review, articleTitle, articleDescription, articleUrl, articleImage, publishDate, author } = Astro.props;

const priceValidUntil = new Date(publishDate);
priceValidUntil.setFullYear(priceValidUntil.getFullYear() + 1);
const priceValidUntilStr = priceValidUntil.toISOString().split('T')[0];

const rawOffers = review.priceRange ? parseOffers(review.priceRange) : null;
const offers = rawOffers ? { ...rawOffers, "priceValidUntil": priceValidUntilStr } : null;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": review.productName,
  "description": articleDescription,
  ...(articleImage && { "image": `${SITE.url}${articleImage}` }),
  ...(review.productBrand && { "brand": { "@type": "Brand", "name": review.productBrand } }),
  ...(offers && { "offers": offers }),
  "review": {
    "@type": "Review",
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": review.rating,
      "bestRating": 5,
      "worstRating": 1
    },
    "author": {
      "@type": "Person",
      "name": author
    },
    "datePublished": publishDate.toISOString(),
    "reviewBody": review.reviewBody || articleDescription,
    "publisher": {
      "@type": "Organization",
      "name": SITE.title
    }
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
