---
import type { CollectionEntry } from 'astro:content';
import OptimizedImage from './OptimizedImage.astro';
import { getPostSlug } from '../utils/blog';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;

// Take the top 18 published posts for a rich variety in filtering
const latestPosts = posts.slice(0, 18);

// Helper to categorize posts by time budget based on tags
function getPostBudget(post: CollectionEntry<'blog'>): string[] {
  const tags = (post.data.tags || []).map(t => t.toLowerCase());
  const budgets: string[] = [];

  // Categorize
  const sideQuestTags = [
    '3d printing', '3d printers', 'filament', 'materials', 'bambu lab', 'creality', 'fdm',
    'photography', 'cameras', 'canon', 'nikon', 'olympus',
    'travel', 'ai travel', 'japan', 'vietnam', 'cambodia', 'asia',
    'japan shopping', 'import guide', 'japanese products',
    'home office', 'desk setup', 'office setup', 'desk accessories',
    'investing', 'finance', 'dividends', 'portfolio tracking', 'stock screeners', 'prediction markets'
  ];
  
  const lunchBreakTags = [
    'career development', 'career', 'career growth', 'career tips', 'promotion',
    'buying guide', 'comparison', 'review', 'retro tech',
    'e-reader', 'kindle', 'kobo', 'accessories',
    'monitors', 'office chairs', 'standing desks', 'ergonomics',
    'tech & gadgets', 'tech \u0026 gadgets', 'earbuds', 'airpods', 'sony',
    'work from home', 'online learning', 'coursera', 'learning'
  ];

  const hasSideQuest = tags.some(tag => sideQuestTags.some(sq => tag.includes(sq)));
  const hasLunchBreak = tags.some(tag => lunchBreakTags.some(lb => tag.includes(lb)));

  if (hasSideQuest) {
    budgets.push('project');
  }
  if (hasLunchBreak) {
    budgets.push('30min');
  }
  
  // Default is 5 mins (snappy prompts, AI tips, quick hacks)
  const hasQuickHacks = tags.some(tag => [
    'ai', 'chatgpt', 'gemini', 'google', 'productivity', 'templates', 'tutorial', 'tips', 
    'quick learning', 'prompt engineering', 'email', 'custom gpts', 'gpt store'
  ].some(qh => tag.includes(qh)));
  
  if (hasQuickHacks || budgets.length === 0) {
    budgets.push('5min');
  }

  return budgets;
}
---

<section class="py-24 relative overflow-hidden bg-background downtime-filter-section">
  <div class="max-w-6xl mx-auto px-4 relative z-10">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-bold mb-4 tracking-tight">How much downtime do you have?</h2>
      <p class="text-lg text-text-light max-w-2xl mx-auto">
        Choose your budget and discover stealthy skills, quick wins, or deep side quests you can master right at your desk.
      </p>
    </div>

    <!-- Active Tab Buttons -->
    <div class="grid grid-cols-1 sm:grid-cols-3 justify-center items-stretch gap-4 mb-16 max-w-3xl mx-auto">
      <button 
        class="downtime-tab-btn group relative flex items-center justify-start gap-4 bg-white rounded-[2rem] p-5 border border-primary/5 shadow-sm hover:shadow-md cursor-pointer transition-all duration-300 active"
        data-filter="5min"
        aria-label="Filter by 5 Minutes"
      >
        <span class="text-4xl animate-emoji animate-emoji-wiggle">⚡</span>
        <div class="text-left">
          <span class="block text-[10px] font-black uppercase tracking-widest text-text-light/50">5 MINS</span>
          <span class="font-bold text-primary group-hover:text-accent transition-colors leading-tight">Quick Hacks</span>
        </div>
      </button>

      <button 
        class="downtime-tab-btn group relative flex items-center justify-start gap-4 bg-white rounded-[2rem] p-5 border border-primary/5 shadow-sm hover:shadow-md cursor-pointer transition-all duration-300"
        data-filter="30min"
        aria-label="Filter by 30 Minutes"
      >
        <span class="text-4xl animate-emoji animate-emoji-wiggle">🍕</span>
        <div class="text-left">
          <span class="block text-[10px] font-black uppercase tracking-widest text-text-light/50">30 MINS</span>
          <span class="font-bold text-primary group-hover:text-accent transition-colors leading-tight">Lunch Break</span>
        </div>
      </button>

      <button 
        class="downtime-tab-btn group relative flex items-center justify-start gap-4 bg-white rounded-[2rem] p-5 border border-primary/5 shadow-sm hover:shadow-md cursor-pointer transition-all duration-300"
        data-filter="project"
        aria-label="Filter by Projects"
      >
        <span class="text-4xl animate-emoji animate-emoji-wiggle">🎮</span>
        <div class="text-left">
          <span class="block text-[10px] font-black uppercase tracking-widest text-text-light/50">PROJECT</span>
          <span class="font-bold text-primary group-hover:text-accent transition-colors leading-tight">Side Quest</span>
        </div>
      </button>
    </div>

    <!-- Filtered Post Grid -->
    <div id="downtime-posts-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 min-h-[450px]">
      {latestPosts.map((post) => {
        const budgets = getPostBudget(post);
        return (
          <article 
            class="downtime-card group bg-white rounded-[2rem] overflow-hidden border border-primary/5 shadow-sm hover:shadow-xl transition-all duration-500 flex flex-col h-full"
            data-budgets={JSON.stringify(budgets)}
          >
            <a href={`/${getPostSlug(post)}/`} class="block overflow-hidden relative aspect-video bg-background-alt">
              {post.data.image ? (
                <OptimizedImage
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  width={400}
                  height={225}
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-4xl">
                  {budgets.includes('5min') ? '⚡' : budgets.includes('30min') ? '🍕' : '🎮'}
                </div>
              )}
            </a>
            
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center gap-3 mb-4">
                {post.data.tags?.slice(0, 1).map(tag => (
                  <span class="text-[10px] font-black uppercase tracking-widest text-accent bg-accent/5 px-2.5 py-1 rounded-full">{tag}</span>
                ))}
                <span class="text-text-light/50 text-[10px] font-bold uppercase tracking-widest">{new Date(post.data.publishDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              </div>

              <h3 class="text-xl font-bold mb-3 line-clamp-2 leading-snug flex-grow">
                <a href={`/${getPostSlug(post)}/`} class="hover:text-accent transition-colors">
                  {post.data.title}
                </a>
              </h3>
              
              <p class="text-sm text-text-light mb-6 line-clamp-2 leading-relaxed">
                {post.data.description}
              </p>

              <div class="pt-4 border-t border-primary/5 flex items-center justify-between">
                <a href={`/${getPostSlug(post)}/`} class="text-sm font-bold text-accent group-hover:underline flex items-center gap-1.5">
                  Start Quest
                  <span class="transition-transform group-hover:translate-x-1">→</span>
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>

  <!-- Decorative background elements -->
  <div class="absolute top-1/2 left-0 w-[500px] h-[500px] bg-accent/5 rounded-full blur-[120px] -translate-y-1/2 -translate-x-1/2 pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-primary/5 rounded-full blur-[100px] translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
</section>

<script>
  function initDowntimeFilter() {
    const tabs = document.querySelectorAll('.downtime-tab-btn');
    const cards = document.querySelectorAll('.downtime-card') as NodeListOf<HTMLElement>;
    
    if (tabs.length === 0 || cards.length === 0) return;

    function filterPosts(filter: string) {
      cards.forEach(card => {
        const budgetsStr = card.getAttribute('data-budgets') || '[]';
        const budgets = JSON.parse(budgetsStr);
        
        if (budgets.includes(filter)) {
          card.style.display = 'flex';
          // Force layout reflow to ensure animation triggers properly
          card.offsetHeight;
          card.classList.add('downtime-card-enter');
        } else {
          card.style.display = 'none';
          card.classList.remove('downtime-card-enter');
        }
      });
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        const filter = btn.getAttribute('data-filter') || '';
        
        // Update active class on buttons
        tabs.forEach(t => t.classList.remove('active'));
        btn.classList.add('active');
        
        // Filter the grid items
        filterPosts(filter);
      });
    });

    // Run once on load to show first category (5min) as active
    filterPosts('5min');
  }

  // Initialize filter
  initDowntimeFilter();
  
  // Re-run filter initialization on Astro view transitions
  document.addEventListener('astro:after-swap', () => {
    initDowntimeFilter();
  });
</script>

<style>
  .downtime-tab-btn.active {
    border-color: var(--color-accent, #7c3aed) !important;
    background-color: var(--color-background-alt, #f5f6ff) !important;
    box-shadow: 0 10px 25px -5px rgba(124, 58, 237, 0.12) !important;
  }
  .downtime-tab-btn.active::before {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 24px;
    right: 24px;
    height: 3px;
    background: var(--color-accent, #7c3aed);
    border-radius: 99px;
  }
  .downtime-tab-btn {
    position: relative;
    outline: none;
  }
  .downtime-tab-btn:focus-visible {
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.3) !important;
  }
</style>
