---
import { Image } from 'astro:assets';

interface Props {
  src: any; // Astro's image object or a string path
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
  widths?: number[];
  sizes?: string;
}

const { 
  src, 
  alt, 
  class: className = '', 
  loading = 'lazy', 
  fetchpriority, 
  width, 
  height, 
  widths,
  sizes 
} = Astro.props;

// If src is a string and it's a relative path from the component (which shouldn't happen much now)
// Or if it's an external URL, Image component handles it.
// If it's a path starting with /images/ (legacy or public), we should warn or handle it.
---

<Image
  src={src}
  alt={alt}
  class={className}
  loading={loading}
  decoding={loading === 'eager' ? 'sync' : 'async'}
  fetchpriority={fetchpriority}
  width={width}
  height={height}
  widths={widths}
  sizes={sizes}
/>
