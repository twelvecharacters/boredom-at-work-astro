---
import OptimizedImage from './OptimizedImage.astro';
import { slugifyTag, getPostSlug, formatPostDate } from '../utils/blog';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const slug = getPostSlug(post);
---

<article class="bg-white rounded-xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
  <div class="md:flex">
    {post.data.image && (
      <div class="md:w-1/3 overflow-hidden">
        <OptimizedImage
          src={post.data.image}
          alt={post.data.imageAlt || post.data.title}
          class="w-full h-48 md:h-full object-cover"
          width={400}
          height={225}
          sizes="(max-width: 768px) 100vw, 33vw"
        />
      </div>
    )}
    <div class="p-6 md:flex-1">
      <div class="flex flex-wrap gap-2 mb-3">
        {post.data.tags.map((tag: string) => (
          <a
            href={`/tags/${slugifyTag(tag)}/`}
            class="bg-background-alt text-text-light hover:bg-accent hover:text-white px-2 py-0.5 rounded text-xs transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>
      <h2 class="text-xl font-bold mb-2">
        <a href={`/${slug}/`} class="hover:text-accent transition-colors">
          {post.data.title}
        </a>
      </h2>
      <p class="text-text-light text-sm mb-4 line-clamp-2">
        {post.data.description}
      </p>
      <div class="flex items-center justify-between">
        <span class="text-text-light text-sm">{formatPostDate(post)}</span>
        <a href={`/${slug}/`} class="text-accent font-medium text-sm hover:underline">
          Read more →
        </a>
      </div>
    </div>
  </div>
</article>
