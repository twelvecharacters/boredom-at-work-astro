    return prompts;
  }

  // ── Init ──
  function init() {
    const textarea = document.getElementById('ep-textarea') as HTMLTextAreaElement;
    const generateBtn = document.getElementById('ep-generate-btn') as HTMLButtonElement;
    const sampleBtn = document.getElementById('ep-sample-btn');
    const resetBtn = document.getElementById('ep-reset-btn');
    const errorEl = document.getElementById('ep-error')!;
    const charCount = document.getElementById('ep-char-count')!;

    if (!textarea || !generateBtn) return;

    // Character counter
    textarea.addEventListener('input', () => {
      const len = textarea.value.length;
      charCount.textContent = len.toLocaleString() + ' characters';
      generateBtn.disabled = len < 100;
    });

    function showError(msg: string) {
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    }

    function hideError() {
      errorEl.classList.add('hidden');
    }

    function processTranscript(text: string) {
      hideError();
      try {
        const info = analyzeTranscript(text);
        const prompts = generatePrompts(info, text.length);

        // Fill summary cards
        document.getElementById('ep-company')!.textContent = info.company;
        document.getElementById('ep-quarter')!.textContent = info.quarter;
        document.getElementById('ep-wordcount')!.textContent = info.wordCount.toLocaleString();
        document.getElementById('ep-has-qa')!.textContent = info.hasQA ? 'Yes' : 'Not detected';

        // Fill prompts
        for (let i = 0; i < prompts.length; i++) {
          document.getElementById(`ep-prompt-${i + 1}`)!.textContent = prompts[i];
        }

        // Show results
        document.getElementById('ep-input-zone')!.classList.add('hidden');
        document.getElementById('ep-results')!.classList.remove('hidden');
      } catch (err: any) {
        showError(err.message || 'Could not analyze transcript.');
      }
    }

    generateBtn.addEventListener('click', () => {
      const text = textarea.value.trim();
      if (text.length < 100) {
        showError('Please paste at least a few hundred words of transcript text.');
        return;
      }
      processTranscript(text);
    });

    sampleBtn?.addEventListener('click', (e) => {
      e.preventDefault();
      textarea.value = SAMPLE_TRANSCRIPT;
      charCount.textContent = SAMPLE_TRANSCRIPT.length.toLocaleString() + ' characters';
      generateBtn.disabled = false;
      processTranscript(SAMPLE_TRANSCRIPT);
    });

    resetBtn?.addEventListener('click', () => {
      document.getElementById('ep-results')!.classList.add('hidden');
      document.getElementById('ep-input-zone')!.classList.remove('hidden');
      textarea.value = '';
      charCount.textContent = '0 characters';
      generateBtn.disabled = true;
      hideError();
    });

    // Copy buttons
    document.querySelectorAll('.ep-copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = (btn as HTMLElement).dataset.target!;
        const text = document.getElementById(targetId)?.textContent || '';
        navigator.clipboard.writeText(text).then(() => {
          const span = btn.querySelector('span') || btn;
          const original = span.textContent;
          span.textContent = 'Copied!';
          (btn as HTMLElement).classList.add('border-green-500', 'text-green-600');
          setTimeout(() => {
            span.textContent = original;
            (btn as HTMLElement).classList.remove('border-green-500', 'text-green-600');
          }, 2000);
        });
      });
    });

    // Enable button if textarea has content
    generateBtn.disabled = textarea.value.length < 100;
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
})();
</script>
