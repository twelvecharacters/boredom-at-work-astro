---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../../../components/Breadcrumbs.astro';
import OptimizedImage from '../../../../../components/OptimizedImage.astro';
import TagCloud from '../../../../../components/TagCloud.astro';
import BlogArchive from '../../../../../components/BlogArchive.astro';
import Pagination from '../../../../../components/Pagination.astro';
import { getPublishedPosts, slugifyTag, getPostSlug } from '../../../../../utils/blog';

import type { GetStaticPathsOptions, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getPublishedPosts();
  
  // Group posts by Year and Month to create paths
  const archiveMap = posts.reduce((acc, post) => {
    const date = post.data.publishDate;
    const year = date.getFullYear().toString();
    const month = (date.getMonth() + 1).toString().padStart(2, '0');
    const key = `${year}/${month}`;
    
    if (!acc[key]) acc[key] = [];
    acc[key].push(post);
    return acc;
  }, {} as Record<string, CollectionEntry<'blog'>[]>);

  return Object.entries(archiveMap).flatMap(([key, monthPosts]) => {
    const [year, month] = key.split('/');
    return paginate(monthPosts, {
      params: { year, month },
      pageSize: 12,
    });
  });
}

interface Props {
  page: Page<CollectionEntry<'blog'>>;
}

const { page } = Astro.props;
const { year, month } = Astro.params;
const posts = page.data;

const monthNames = [
  "January", "February", "March", "April", "May", "June",
  "July", "August", "September", "October", "November", "December"
];
const monthName = monthNames[parseInt(month) - 1];

const breadcrumbItems = [
  { name: 'Blog', url: '/blog/' },
  { name: `${monthName} ${year}`, url: `/blog/archive/${year}/${month}/` }
];
---

<BaseLayout 
  title={`Articles from ${monthName} ${year} — Boredom at Work ${page.currentPage > 1 ? `- Page ${page.currentPage}` : ''}`} 
  description={`Browse our collection of articles from ${monthName} ${year}. AI tools, 3D printing, and productivity guides.`}
  noindex={true}
  prevUrl={page.url.prev} 
  nextUrl={page.url.next}
>
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid lg:grid-cols-4 gap-12">
        <div class="lg:col-span-3">
          <Breadcrumbs items={breadcrumbItems} />
          <h1 class="text-3xl md:text-4xl font-bold mb-4">Archive: {monthName} {year}</h1>
          <p class="text-text-light mb-8">
            Showing all articles published in {monthName} {year}.
          </p>

          {posts.length > 0 ? (
            <div class="space-y-8">
              {posts.map((post) => (
                <article class="bg-white rounded-xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                  <div class="md:flex">
                    {post.data.image && (
                      <div class="md:w-1/3 overflow-hidden">
                        <OptimizedImage
                          src={post.data.image}
                          alt={post.data.title}
                          class="w-full h-48 md:h-full object-cover"
                          width={400}
                          height={225}
                        />
                      </div>
                    )}
                    <div class="p-6 md:flex-1">
                      <div class="flex flex-wrap gap-2 mb-3">
                        {post.data.tags.map((tag: string) => (
                          <a
                            href={`/tags/${slugifyTag(tag)}/`}
                            class="bg-background-alt text-text-light hover:bg-accent hover:text-white px-2 py-0.5 rounded text-xs transition-colors"
                          >
                            {tag}
                          </a>
                        ))}
                      </div>
                      <h2 class="text-xl font-bold mb-2">
                        <a href={`/${getPostSlug(post)}/`} class="hover:text-accent transition-colors">
                          {post.data.title}
                        </a>
                      </h2>
                      <p class="text-text-light text-sm mb-4 line-clamp-2">
                        {post.data.description}
                      </p>
                      <div class="flex items-center justify-between">
                        <span class="text-text-light text-sm">
                          {post.data.publishDate.toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric'
                          })}
                        </span>
                        <a href={`/${getPostSlug(post)}/`} class="text-accent font-medium text-sm hover:underline">
                          Read more →
                        </a>
                      </div>
                    </div>
                  </div>
                </article>
              ))}
              
              <Pagination page={page} />
            </div>
          ) : (
            <div class="text-center py-12 bg-background-alt rounded-xl">
              <p class="text-text-light">No posts found for this period.</p>
            </div>
          )}
        </div>
        
        <aside class="lg:col-span-1">
          <div class="sticky top-24">
            <TagCloud />
            <BlogArchive />
            
            <div class="mt-8 bg-primary rounded-2xl p-6 text-white overflow-hidden relative">
              <div class="absolute top-0 right-0 w-24 h-24 bg-accent/20 rounded-full -mr-12 -mt-12"></div>
              <h3 class="font-bold mb-2 relative z-10">Bored at Work?</h3>
              <p class="text-white/80 text-sm mb-4 relative z-10">
                Turn your downtime into career growth with our curated guides.
              </p>
              <a href="/productive-things-bored-at-work/" class="inline-block bg-white text-primary px-4 py-2 rounded-lg text-xs font-bold hover:bg-gray-100 transition-colors relative z-10">
                Get Started →
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
