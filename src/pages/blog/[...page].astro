---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PostCard from '../../components/PostCard.astro';
import SidebarCTA from '../../components/SidebarCTA.astro';
import TagCloud from '../../components/TagCloud.astro';
import BlogArchive from '../../components/BlogArchive.astro';
import Pagination from '../../components/Pagination.astro';
import { getPublishedPosts, POSTS_PER_PAGE } from '../../utils/blog';

import type { GetStaticPathsOptions, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getPublishedPosts();
  return paginate(posts, { pageSize: POSTS_PER_PAGE });
}

interface Props {
  page: Page<CollectionEntry<'blog'>>;
}

const { page } = Astro.props;
const posts = page.data;

const breadcrumbItems = [
  { name: 'Blog', url: '/blog/' }
];
---

<BaseLayout title={`Blog, AI Tools, 3D Printing, Tech Guides ${page.currentPage > 1 ? `- Page ${page.currentPage}` : ''}`} description="Practical guides for office workers: AI tools, 3D printing, photography, desk setup, and tech reviews. Turn your work downtime into skills." noindex={page.currentPage > 1} prevUrl={page.url.prev} nextUrl={page.url.next}>
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid lg:grid-cols-4 gap-12">
        <div class="lg:col-span-3">
          <Breadcrumbs items={breadcrumbItems} />
          <h1 class="text-3xl md:text-4xl font-bold mb-4">Blog, Guides, Tutorials & Reviews</h1>
          <p class="text-text-light mb-8">
            Practical guides for office workers: AI tools, 3D printing, photography, desk setup, and tech reviews.
          </p>

          {posts.length > 0 ? (
            <div class="space-y-8">
              {posts.map((post: any) => (
                <PostCard post={post} />
              ))}
              
              <Pagination page={page} />
            </div>
          ) : (
            <div class="text-center py-12 bg-background-alt rounded-xl">
              <p class="text-text-light">No posts yet. Check back soon!</p>
            </div>
          )}
        </div>
        
        <aside class="lg:col-span-1">
          <div class="sticky top-24">
            <TagCloud />
            <BlogArchive />
            
            <SidebarCTA />
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
